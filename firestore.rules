
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admins can read/write anywhere
    function isAdmin() {
      return request.auth.token.email == 'care@aziaf.com';
    }

    // Users collection
    match /users/{userId} {
      // A user can read/write their own document
      allow read, write: if request.auth.uid == userId || isAdmin();

      // Onboarding subcollection
      match /onboarding/{docId} {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }

      // Diet Plan subcollection
      match /dietPlan/{docId} {
        // Users can read their own plan, admins can write it
        allow read: if request.auth.uid == userId || isAdmin();
        allow write: if isAdmin();
      }
      
      // Progress subcollection
      match /progress/{logId} {
         allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }
    
    // Payments collection
    match /payments/{userId} {
        // A user can create their own payment document
        // Admins can read/update it for verification
        allow create: if request.auth.uid == userId;
        allow read, update: if isAdmin();
    }

    // Team collection
    match /team/{memberId} {
        // Any authenticated user can read the team list (for assignment dropdown)
        // Only admins can create/update/delete team members
        allow read: if request.auth != null || isAdmin();
        allow write: if isAdmin();
    }

    // Reviews collection
    match /reviews/{reviewId} {
        // Only admins/team can read and write reviews
        allow read, write: if isAdmin();
    }
  }
}
