
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── User Documents ───
    match /users/{userId} {
      // Users can read their own document; admins can read all
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own document during signup
      allow create: if isOwner(userId);
      // Users can update their own document; admins can update any
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete user documents
      allow delete: if isAdmin();

      // Subcollections (onboarding, dietPlan, etc.)
      match /{subcollection}/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // ─── Team Members (admin-only) ───
    match /team/{memberId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Plan Reviews (admin-only write, user can read their own) ───
    match /reviews/{reviewId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── Payments ───
    match /payments/{paymentId} {
      // Users can create/read their own payment; admins can do everything
      allow read: if isAuthenticated() && (request.auth.uid == paymentId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == paymentId;
      allow update, delete: if isAdmin();
    }

    // ─── Knowledge Base (admin-only write, server reads) ───
    match /knowledge-base/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
