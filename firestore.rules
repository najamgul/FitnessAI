
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY DEBUG RULES - DO NOT USE IN PRODUCTION
    // This will help identify which specific query is failing
    
    match /users/{userId} {
      // Allow all authenticated users to read/write for debugging
      allow read, write, list: if request.auth != null;
      
      // Allow all operations for subcollections temporarily
      match /{subcollection}/{docId} {
        allow read, write, list: if request.auth != null;
      }
    }
    
    match /team/{memberId} {
      // Allow all authenticated users temporarily
      allow read, write, list: if request.auth != null;
    }
    
    match /reviews/{reviewId} {
      // Allow all authenticated users temporarily
      allow read, write, list: if request.auth != null;
    }
    
    match /payments/{paymentId} {
      // Allow all authenticated users temporarily
      allow read, write, list: if request.auth != null;
    }
    
    // Catch-all rule for debugging - remove after identifying the issue
    match /{document=**} {
      allow read, write, list: if request.auth != null;
    }
  }
}
